<Window x:Class="QuickPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:QuickPrompt.Helpers"
        Title="QuickPrompt"
        Width="560"
        Height="78"
        MinWidth="420"
        MinHeight="74"
        MaxHeight="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#F3F8FF"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="OverlayBorderBrush" Color="#5EFFFFFF" />
        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#84111822" />
        <SolidColorBrush x:Key="OverlayChipBrush" Color="#330D1522" />
        <SolidColorBrush x:Key="OverlayChipBorderBrush" Color="#2AFFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B7CBDD" />

        <Style x:Key="TinyButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FB" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3BFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OverlayRoot"
            Margin="10"
            Padding="14,10"
            Background="{StaticResource OverlayPanelBrush}"
            BorderBrush="{StaticResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="30"
            MouseLeftButtonDown="Root_OnMouseLeftButtonDown"
            MouseEnter="Root_OnMouseEnter">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#CA000000" Opacity="0.62" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="QuickPrompt"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Border Margin="8,0,0,0"
                            Padding="8,2"
                            Background="#1F48CFE0"
                            CornerRadius="10">
                        <TextBlock Text="{Binding StatusAccentText}" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding StatusText}"
                               Margin="10,0,0,0"
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               MaxWidth="320"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TinyButtonStyle}"
                            Content="⟳"
                            ToolTip="Refresh models"
                            Command="{Binding RefreshModelsCommand}" />
                    <Button Style="{StaticResource TinyButtonStyle}"
                            Content="⚙"
                            ToolTip="Settings"
                            Command="{Binding OpenSettingsCommand}" />
                    <Button Style="{StaticResource TinyButtonStyle}"
                            Content="{Binding Overlay.PinGlyph}"
                            ToolTip="Pin / unpin"
                            Command="{Binding TogglePinCommand}" />
                    <Button Style="{StaticResource TinyButtonStyle}"
                            Content="⌁"
                            ToolTip="New chat"
                            Command="{Binding NewChatCommand}" />
                    <Button Style="{StaticResource TinyButtonStyle}"
                            Margin="0"
                            Content="—"
                            ToolTip="Hide"
                            Click="HideButton_OnClick" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,8"
                    Padding="8,6"
                    Background="#1DFFFFFF"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Visibility="{Binding HasConversation, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListBox x:Name="ChatList"
                         ItemsSource="{Binding Messages}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MaxHeight="300">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{Binding SenderLabel}"
                                           FontSize="10"
                                           Foreground="#8EB2D0" />
                                <Border Margin="0,4,0,0"
                                        Padding="10,8"
                                        Background="#1F0E1622"
                                        CornerRadius="12">
                                    <helpers:MarkdownViewer Markdown="{Binding Markdown}"
                                                            IsUserMessage="{Binding IsUser}" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="2"
                    Padding="12,8"
                    Background="{StaticResource OverlayChipBrush}"
                    BorderBrush="{StaticResource OverlayChipBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Visibility="{Binding AttachmentVisibility}">
                <TextBlock Text="{Binding AttachmentStatus}" FontSize="11" Foreground="#CEE2F3" />
            </Border>

            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="PromptTextBox"
                             AcceptsReturn="True"
                             MaxHeight="100"
                             MinHeight="42"
                             VerticalContentAlignment="Center"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontSize="14"
                             Padding="16,10,42,10"
                             BorderThickness="1"
                             BorderBrush="#28FFFFFF"
                             Background="#2A0F1722"
                             Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             GotFocus="PromptTextBox_OnGotFocus"
                             LostFocus="PromptTextBox_OnLostFocus" />
                    <TextBlock Margin="16,12,40,0"
                               IsHitTestVisible="False"
                               Text="Ask anything… Enter — send, Shift+Enter — newline"
                               FontSize="12"
                               Foreground="#77C2D6E8"
                               Visibility="{Binding PromptPlaceholderVisibility}" />
                </Grid>

                <Button Grid.Column="1"
                        Style="{StaticResource TinyButtonStyle}"
                        Content="📷"
                        ToolTip="Attach screenshot"
                        Command="{Binding CaptureScreenshotCommand}" />

                <Button Grid.Column="2"
                        Style="{StaticResource TinyButtonStyle}"
                        Content="⌘"
                        ToolTip="Paste clipboard"
                        Command="{Binding PasteClipboardCommand}" />

                <Button Grid.Column="3"
                        Width="40"
                        Height="40"
                        Margin="8,0,0,0"
                        Background="#7748CEE0"
                        BorderBrush="#45FFFFFF"
                        BorderThickness="1"
                        Foreground="#041118"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Content="➤"
                        Command="{Binding SendCommand}" />
            </Grid>
        </Grid>
    </Border>
</Window>
