<Window x:Class="QuickPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPrompt"
        Width="460"
        Height="700"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1F22"
        Foreground="#F3F3F3"
        Topmost="True">
    <Border Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Model" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding Models}"
                          SelectedItem="{Binding SelectedModel}"
                          Background="#2B2D31"
                          Foreground="#F3F3F3"/>
                <Button Content="↻" Width="36" Margin="8,0,0,0" Command="{Binding RefreshModelsCommand}"/>
                <Button Content="Settings" Margin="8,0,0,0" Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#151618" Padding="8">
                <TextBlock Text="{Binding ResponseText}" TextWrapping="Wrap"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,6">
                <Button Content="Сделать скрин" Command="{Binding CaptureScreenshotCommand}"/>
                <Button Content="Вставить буфер" Margin="8,0,0,0" Command="{Binding PasteClipboardCommand}"/>
                <Button Content="Очистить" Margin="8,0,0,0" Command="{Binding ClearSessionCommand}"/>
                <TextBlock Text="{Binding ScreenshotStatus}" Margin="10,6,0,0" FontStyle="Italic"/>
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}" 
                         Height="76"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#2B2D31"
                         Foreground="#F3F3F3"/>
                <Button Grid.Column="1" Content="Send" Margin="8,0,0,0" Padding="14,6" Command="{Binding SendCommand}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
