<Window x:Class="QuickPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:QuickPrompt.Helpers"
        Title="QuickPrompt"
        Width="640"
        Height="86"
        MinWidth="440"
        MinHeight="78"
        MaxHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#F4F7FB"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceFill" Color="#B3161A22" />
        <SolidColorBrush x:Key="SurfaceBorder" Color="#57FFFFFF" />
        <SolidColorBrush x:Key="InputFill" Color="#8A0F141D" />
        <SolidColorBrush x:Key="InputBorder" Color="#42FFFFFF" />
        <SolidColorBrush x:Key="DividerBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="SecondaryText" Color="#A5BECE" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#19000000" />
            <Setter Property="Foreground" Value="#DCE5EF" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#38FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MessageItemStyle" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OverlayRoot"
            Margin="8"
            Padding="14,12"
            CornerRadius="26"
            Background="{StaticResource SurfaceFill}"
            BorderBrush="{StaticResource SurfaceBorder}"
            BorderThickness="1"
            MouseLeftButtonDown="Root_OnMouseLeftButtonDown"
            MouseEnter="Root_OnMouseEnter">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="0" Color="#C9000000" Opacity="0.58" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Spotlight-like command row -->
            <Border Grid.Row="0"
                    Background="{StaticResource InputFill}"
                    BorderBrush="{StaticResource InputBorder}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="15"
                               Foreground="#9DB4C8"
                               Text="⌘" />

                    <Grid Grid.Column="1">
                        <TextBox x:Name="PromptTextBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#F5FAFF"
                                 FontSize="15"
                                 FontFamily="Segoe UI Variable Text, Segoe UI"
                                 AcceptsReturn="True"
                                 MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                                 GotFocus="PromptTextBox_OnGotFocus"
                                 LostFocus="PromptTextBox_OnLostFocus" />
                        <TextBlock IsHitTestVisible="False"
                                   Margin="0,2,0,0"
                                   FontSize="13"
                                   Foreground="#78BDD0E1"
                                   Text="Ask anything — Enter to send"
                                   Visibility="{Binding PromptPlaceholderVisibility}" />
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="📎"
                                ToolTip="Attach screenshot"
                                Command="{Binding CaptureScreenshotCommand}" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Content="↺"
                                ToolTip="Paste clipboard"
                                Command="{Binding PasteClipboardCommand}" />
                        <Button Width="30"
                                Height="30"
                                Margin="0"
                                Background="#7A50D6E8"
                                BorderBrush="#58FFFFFF"
                                BorderThickness="1"
                                Foreground="#061119"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Content="↑"
                                Command="{Binding SendCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="4,10,4,8"
                    Height="1"
                    Background="{StaticResource DividerBrush}"
                    Visibility="{Binding MessagesVisibility}" />

            <!-- Lightweight transcript -->
            <Border Grid.Row="2"
                    Visibility="{Binding MessagesVisibility}">
                <ListBox x:Name="ChatList"
                         ItemContainerStyle="{StaticResource MessageItemStyle}"
                         ItemsSource="{Binding Messages}"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="300"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Margin="0,0,10,0"
                                           FontSize="11"
                                           Foreground="#8FAFC5"
                                           VerticalAlignment="Top"
                                           Text="{Binding SenderLabel}" />

                                <StackPanel Grid.Column="1">
                                    <helpers:MarkdownViewer Markdown="{Binding Markdown}"
                                                            IsUserMessage="{Binding IsUser}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="10"
                                               Foreground="#7190A8"
                                               Text="{Binding TimeLabel}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Status + minimal controls -->
            <Grid Grid.Row="3"
                  Margin="0,10,0,0"
                  Visibility="{Binding ControlsVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryText}" Text="QuickPrompt" />
                    <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#88D1DEE9" Text="•" />
                    <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="{StaticResource SecondaryText}" Text="{Binding StatusAccentText}" />
                    <TextBlock Margin="8,0,0,0"
                               FontSize="11"
                               Foreground="#88A8C0D2"
                               MaxWidth="320"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding StatusText}"
                               Visibility="{Binding StatusVisibility}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButtonStyle}" Content="⟳" ToolTip="Refresh models" Command="{Binding RefreshModelsCommand}" />
                    <Button Style="{StaticResource IconButtonStyle}" Content="⚙" ToolTip="Settings" Command="{Binding OpenSettingsCommand}" />
                    <Button Style="{StaticResource IconButtonStyle}" Content="{Binding Overlay.PinGlyph}" ToolTip="Pin / unpin" Command="{Binding TogglePinCommand}" />
                    <Button Style="{StaticResource IconButtonStyle}" Content="⌁" ToolTip="New chat" Command="{Binding NewChatCommand}" />
                    <Button Style="{StaticResource IconButtonStyle}" Margin="0" Content="✕" ToolTip="Hide" Click="HideButton_OnClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
