<Window x:Class="QuickPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:QuickPrompt.Helpers"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="QuickPrompt"
        Width="980"
        Height="820"
        MinWidth="860"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#081018"
        Foreground="#F5F7FB"
        ShowInTaskbar="False"
        Topmost="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="26"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <LinearGradientBrush x:Key="WindowGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0F172A" Offset="0" />
            <GradientStop Color="#FF09111A" Offset="0.55" />
            <GradientStop Color="#FF101826" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="UserBubbleBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF1B8B99" Offset="0" />
            <GradientStop Color="#FF18607E" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#D9131922" />
        <SolidColorBrush x:Key="ErrorBubbleBrush" Color="#E8261624" />
        <SolidColorBrush x:Key="PanelBrush" Color="#A30F1720" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9BB0C7" />
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#ECF4FF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF35C6D7" />

        <Style x:Key="SurfaceButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#1CFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SurfaceButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FF051218" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF4CDBE7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF2FB2C4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource SurfaceButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="#20FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinWidth" Value="220" />
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#160E1520" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="#1CFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,18,18,18" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Background="{StaticResource WindowGlowBrush}"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            CornerRadius="26">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Color="#B0000000" Opacity="0.65" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.RowSpan="3" IsHitTestVisible="False">
                <Ellipse Width="320"
                         Height="320"
                         Fill="#1835C6D7"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,-120,-80,0" />
                <Ellipse Width="260"
                         Height="260"
                         Fill="#16F97316"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"
                         Margin="-80,0,0,-100" />
                <Rectangle Fill="#05FFFFFF" />
            </Grid>

            <Border Grid.Row="0"
                    Background="#16FFFFFF"
                    BorderBrush="#16FFFFFF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="26,26,0,0"
                    Padding="26,22,26,20"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="QuickPrompt"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderTextBrush}" />
                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="24,0,16,0"
                            Padding="14,12"
                            Background="#12000000"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Модель"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                      ItemsSource="{Binding Models}"
                                      SelectedItem="{Binding SelectedModel}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Style="{StaticResource SurfaceButtonStyle}"
                                Content="Обновить"
                                Command="{Binding RefreshModelsCommand}" />
                        <Button Style="{StaticResource SurfaceButtonStyle}"
                                Content="Настройки"
                                Command="{Binding OpenSettingsCommand}" />
                        <Button Style="{StaticResource SurfaceButtonStyle}"
                                Content="Новая сессия"
                                Command="{Binding NewChatCommand}" />
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Content="−"
                                Margin="6,0,6,0"
                                Click="HideButton_OnClick" />
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Content="×"
                                Click="CloseButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="20,18,20,18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <ListBox x:Name="ChatList"
                             ItemsSource="{Binding Messages}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="28,24,28,24"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Bubble"
                                        MaxWidth="580"
                                        Margin="0,0,0,16"
                                        Padding="18,16"
                                        HorizontalAlignment="{Binding BubbleAlignment}"
                                        Background="{StaticResource AssistantBubbleBrush}"
                                        BorderBrush="#16FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                            <TextBlock Text="{Binding SenderLabel}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#AFC2D8" />
                                            <Border Margin="10,0,0,0"
                                                    Padding="8,3"
                                                    Background="#16000000"
                                                    BorderBrush="#18FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Visibility="{Binding HasAttachmentPill, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Скриншот"
                                                           FontSize="11"
                                                           Foreground="#D7E5F2" />
                                            </Border>
                                            <Border Margin="8,0,0,0"
                                                    Padding="8,3"
                                                    Background="#16000000"
                                                    BorderBrush="#18FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Visibility="{Binding HasStatePill, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding StatePillText}"
                                                           FontSize="11"
                                                           Foreground="#D7E5F2" />
                                            </Border>
                                            <TextBlock Text="{Binding TimeLabel}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="#88A2C1" />
                                        </DockPanel>
                                        <helpers:MarkdownViewer Markdown="{Binding Markdown}"
                                                                IsUserMessage="{Binding IsUser}" />
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBrush}" />
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="#28FFFFFF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter TargetName="Bubble" Property="Background" Value="{StaticResource ErrorBubbleBrush}" />
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="#40FF8AA0" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel Width="460"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border Width="70"
                                    Height="70"
                                    HorizontalAlignment="Center"
                                    Background="#14000000"
                                    BorderBrush="#1EFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <TextBlock Text="QP"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display, Segoe UI"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="#DAF4FF" />
                            </Border>

                            <TextBlock Text="Спросите что угодно"
                                       Margin="0,24,0,0"
                                       TextAlignment="Center"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       Foreground="#F3F7FD" />

                            <TextBlock Text="История этой сессии хранится внутри приложения, а ответы модели можно читать с Markdown-форматированием, списками, заголовками и кодом."
                                       Margin="0,16,0,0"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="15"
                                       Foreground="{StaticResource MutedTextBrush}" />

                            <WrapPanel Margin="0,24,0,0" HorizontalAlignment="Center">
                                <Border Margin="0,0,10,10"
                                        Padding="12,8"
                                        Background="#14000000"
                                        BorderBrush="#18FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="Markdown ready" Foreground="#DCE9F6" />
                                </Border>
                                <Border Margin="0,0,10,10"
                                        Padding="12,8"
                                        Background="#14000000"
                                        BorderBrush="#18FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="Скриншоты одним кликом" Foreground="#DCE9F6" />
                                </Border>
                                <Border Margin="0,0,10,10"
                                        Padding="12,8"
                                        Background="#14000000"
                                        BorderBrush="#18FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="Новая сессия при закрытии" Foreground="#DCE9F6" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="20,0,20,20"
                    Padding="20"
                    Background="#AA101824"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource SurfaceButtonStyle}"
                                Content="Сделать скриншот"
                                Command="{Binding CaptureScreenshotCommand}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource SurfaceButtonStyle}"
                                Content="Вставить буфер"
                                Command="{Binding PasteClipboardCommand}" />

                        <Border Grid.Column="2"
                                HorizontalAlignment="Right"
                                Padding="12,8"
                                Background="#12000000"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{Binding AttachmentVisibility}">
                            <TextBlock Text="{Binding AttachmentStatus}"
                                       Foreground="#D7E6F5"
                                       FontSize="12" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <TextBox x:Name="PromptTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     AcceptsReturn="True"
                                     MinHeight="136"
                                     MaxHeight="260"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="PromptTextBox_OnPreviewKeyDown" />
                            <TextBlock Margin="20,18,80,0"
                                       IsHitTestVisible="False"
                                       Text="Напишите сообщение или вставьте Markdown. Enter отправляет запрос, Shift+Enter добавляет новую строку."
                                       TextWrapping="Wrap"
                                       Foreground="#66D7E2F0"
                                       Visibility="{Binding PromptPlaceholderVisibility}" />
                        </Grid>

                        <Button Grid.Column="1"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="150"
                                Height="56"
                                Margin="16,0,0,0"
                                VerticalAlignment="Bottom"
                                Content="Отправить"
                                Command="{Binding SendCommand}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
